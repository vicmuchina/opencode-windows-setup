{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "skills": [
        "*"
      ]
    },
    "plan": {
      "skills": [
        "*"
      ]
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserveTokens": 16000
  },
  "default_agent": "build",
  "mcp": {
    "chrome-devtools": {
      "command": [
        "node",
        "C:\\Users\\steph\\AppData\\Roaming\\npm\\node_modules\\chrome-devtools-mcp\\build\\src\\index.js",
        "--browserUrl",
        "http://127.0.0.1:9333",
        "--viewport=1280x720"
      ],
      "enabled": true,
      "timeout": 45000,
      "type": "local"
    },
    "context7": {
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "environment": {
        "CONTEXT7_API_KEY": "ctx7sk-cdba4742-32b9-4585-90fb-8783979b008a"
      },
      "timeout": 45000,
      "type": "local"
    },
    "deepwiki": {
      "command": [
        "python",
        "C:\\Users\\steph\\.config\\opencode\\deepwiki-bridge\\bridge.py"
      ],
      "enabled": true,
      "environment": {},
      "timeout": 45000,
      "type": "local"
    },
    "tavily": {
      "command": [
        "npx",
        "-y",
        "tavily-mcp@latest"
      ],
      "enabled": true,
      "environment": {
        "TAVILY_API_KEY": "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"
      },
      "timeout": 45000,
      "type": "local"
    }
  },
  "permission": {
    "bash": "allow",
    "doom_loop": "allow",
    "edit": "allow",
    "external_directory": "allow",
    "skill": "allow",
    "webfetch": "allow"
  },
  "plugin": [
    "opencode-antigravity-auth@latest",
    "opencode-skills",
    "opencode-pty"
  ],
  "provider": {
    "chutes": {
      "models": {
        "moonshotai/Kimi-K2-Thinking": {
          "limit": {
            "context": 200000,
            "output": 16384
          },
          "name": "Kimi K2 Thinking"
        },
        "moonshotai/Kimi-K2.5-TEE": {
          "limit": {
            "context": 200000,
            "output": 16384
          },
          "name": "Kimi K2.5 TEE"
        },
        "xiaomimimo/mimo-v2-flash": {
          "limit": {
            "context": 256000,
            "output": 32000
          },
          "name": "MiMo V2 Flash",
          "options": {
            "reasoning_effort": "max",
            "thinking": "preserved"
          }
        },
        "zai-org/GLM-4.7-TEE": {
          "limit": {
            "context": 190000,
            "output": 131072
          },
          "name": "GLM 4.7",
          "options": {
            "reasoning_effort": "max",
            "thinking": "preserved"
          }
        },
        "zai-org/GLM-5-FP8": {
          "limit": {
            "context": 200000,
            "output": 131072
          },
          "name": "GLM 5 FP8"
        }
      },
      "name": "Chutes AI",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "cpk_749238160b2b4adca1f02a57b97315cd.3470a1f8f3b25e23a7ba64cb79f7b081.TPuqwu1FsD6QmBLtRrICThuBd0HODnVW",
        "baseURL": "https://llm.chutes.ai/v1"
      }
    },
    "bailian-coding-plan": {
      "name": "Alibaba DashScope",
      "npm": "@ai-sdk/anthropic",
      "options": {
        "apiKey": "sk-sp-538c754005aa4fc08d2f82331479ac05",
        "baseURL": "https://coding-intl.dashscope.aliyuncs.com/apps/anthropic/v1"
      },
      "models": {
        "kimi-k2.5": {
          "name": "Kimi K2.5 (DashScope)",
          "limit": {
            "context": 262144,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
